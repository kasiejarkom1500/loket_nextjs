generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Service {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  color     String?
  createdAt DateTime @default(now())
  queues    Queue[]
}

model Counter {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  queues    Queue[]
  users     User[]
  assignments Assignment[]
}

model User {
  id        Int      @id @default(autoincrement())
  nipLama   String   @map("nip_lama")
  username  String   @unique
  password  String
  nama      String
  counterId Int?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  counter Counter? @relation(fields: [counterId], references: [id])
  assignments Assignment[]
  queuesAsPublicOfficer Queue[] @relation("PublicOfficer")
  queuesAsDataOfficer Queue[] @relation("DataOfficer")
  attendances Attendance[]
}

model Queue {
  id         Int         @id @default(autoincrement())
  number     String
  status     QueueStatus @default(PENDING)
  visitorId  Int?
  staffPurposeDetail String? @default("")
  publicOfficerId Int?
  dataOfficerId Int?
  securityOfficerId Int?
  serviceId  Int
  counterId  Int?
  createdAt  DateTime    @default(now())
  calledAt   DateTime?
  completedAt DateTime?

  visitor Visitor? @relation(fields: [visitorId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  counter Counter? @relation(fields: [counterId], references: [id])
  publicOfficer User? @relation("PublicOfficer", fields: [publicOfficerId], references: [id])
  dataOfficer User? @relation("DataOfficer", fields: [dataOfficerId], references: [id])
  securityOfficer SecurityOfficer? @relation(fields: [securityOfficerId], references: [id])
  rating  Rating?
}

model Assignment {
  id        Int            @id @default(autoincrement())
  userId    Int
  role      AssignmentRole
  shift     Shift
  date      DateTime
  counterId Int?
  createdAt DateTime       @default(now())

  user    User    @relation(fields: [userId], references: [id])
  counter Counter? @relation(fields: [counterId], references: [id])

  @@unique([userId, date, shift])
}

model Visitor {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  origin    String
  purpose   String
  createdAt DateTime @default(now())
  queues    Queue[]
}

model Rating {
  id        Int      @id @default(autoincrement())
  queueId   Int      @unique
  score     Int
  publicOfficerScore Int?
  dataOfficerScore Int?
  securityOfficerScore Int?
  comment   String?
  createdAt DateTime @default(now())

  queue Queue @relation(fields: [queueId], references: [id])
}

model SecurityOfficer {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  queues    Queue[]
}

model Attendance {
  id        Int            @id @default(autoincrement())
  userId    Int
  role      AttendanceRole
  shift     Shift
  date      DateTime
  checkInAt DateTime?
  checkOutAt DateTime?

  publicNondataOffline Int?
  publicNondataOnline Int?
  publicComplaintsOffline Int?
  publicSkdCount Int?
  publicNotes String?

  dataRequestOffline Int?
  dataConsultOffline Int?
  dataRequestOnline Int?
  dataConsultOnline Int?
  dataNotes String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date, shift, role])
}

model ShiftSetting {
  id        Int      @id @default(autoincrement())
  shift     Shift    @unique
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum QueueStatus {
  PENDING
  CALLED
  COMPLETED
}

enum AssignmentRole {
  LAYANAN_PUBLIK
  PERMINTAAN_DATA
}

enum Shift {
  PAGI
  SIANG
}

enum AttendanceRole {
  LAYANAN_PUBLIK
  PERMINTAAN_DATA
}
